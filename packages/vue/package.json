{
  "name": "@fluxiapi/vue",
  "version": "0.3.3",
  "description": "Vue DevTools for FluxAPI — live API health monitoring with Vue Query & Pinia integration",
  "author": "Aswin <aswin@fluxapi.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aswinsasi/fluxapi.git",
    "directory": "packages/vue"
  },
  "homepage": "https://fluxapi.dev",
  "bugs": {
    "url": "https://github.com/aswinsasi/fluxapi/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "keywords": [
    "fluxapi",
    "vue",
    "vue3",
    "nuxt",
    "devtools",
    "api-health",
    "vue-query",
    "pinia",
    "performance",
    "monitoring",
    "network"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "vue": ">=3.3.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/vue-query": {
      "optional": true
    }
  },
  "dependencies": {
    "@fluxiapi/scan": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.33",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1",
    "vue": "^3.5.13"
  }
}
